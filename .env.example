# Cloudflare (see: https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
TUNNEL_NAME=ollama-tunnel

# Cloudflare Access (optional — set to true to protect with service token auth)
ACCESS_ENABLED=true

# Ollama
OLLAMA_MODEL=tinyllama

# Test script
OLLAMA_HOSTNAME=ollama.example.com

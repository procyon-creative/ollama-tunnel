# Cloudflare (see: https://dash.cloudflare.com/profile/api-tokens)
# Required permissions: Account: Cloudflare Tunnel (Edit), Zone: DNS (Edit), Zone: Firewall Services (Write)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
TUNNEL_NAME=ollama-tunnel

# API key — clients use Authorization: Bearer <key> (standard OpenAI format)
API_KEY=sk-change-me

# Ollama
OLLAMA_MODEL=tinyllama

# Test script
OLLAMA_HOSTNAME=ollama.example.com
